# Coralogix repo-tracker hook configuration
# Copy this file to ~/.claude/hooks/.env and fill in your values.
# Or set these as env vars in Claude Code Managed Settings (recommended for teams).

# Required: Your Coralogix Send-Your-Data API key
# Find it under Settings > API Keys in your Coralogix tenant
CX_HOOK_API_KEY=<your-send-your-data-api-key>

# OTLP ingress endpoint for your Coralogix region
# us1: https://ingress.us1.coralogix.com
# us2: https://ingress.us2.coralogix.com
# eu1: https://ingress.eu1.coralogix.com
# eu2: https://ingress.eu2.coralogix.com
# ap1: https://ingress.ap1.coralogix.com
# ap2: https://ingress.ap2.coralogix.com
# ap3: https://ingress.ap3.coralogix.com
CX_HOOK_OTLP_ENDPOINT=https://ingress.eu2.coralogix.com

# Application and subsystem names for Coralogix resource attributes
CX_HOOK_APPLICATION_NAME=claude-code
CX_HOOK_SUBSYSTEM_NAME=ai-agent
