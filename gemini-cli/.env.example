# Coralogix Send-Your-Data API key
CX_API_KEY=your-coralogix-private-key-here

# Coralogix OTLP ingress endpoint (no signal suffix)
CX_OTLP_ENDPOINT=https://ingress.<coralogix_region>.coralogix.com

# Coralogix application and subsystem names
CX_APPLICATION_NAME=gemini-cli
CX_SUBSYSTEM_NAME=gemini-cli-sessions
