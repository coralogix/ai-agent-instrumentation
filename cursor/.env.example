# Coralogix credentials
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# Send-Your-Data API key from Settings → API Keys in your Coralogix tenant
CX_API_KEY=

# OTLP ingress endpoint for your Coralogix region:
#   us1: https://ingress.us1.coralogix.com
#   us2: https://ingress.us2.coralogix.com
#   eu1: https://ingress.eu1.coralogix.com
#   eu2: https://ingress.eu2.coralogix.com
#   ap1: https://ingress.ap1.coralogix.com
#   ap2: https://ingress.ap2.coralogix.com
#   ap3: https://ingress.ap3.coralogix.com
CX_OTLP_ENDPOINT=https://ingress.eu2.coralogix.com

# How events appear in Coralogix Logs / Traces
CX_APPLICATION_NAME=cursor
CX_SUBSYSTEM_NAME=ai-agent

# Set to "true" to redact prompt content from all spans
CURSOR_MASK_PROMPTS=false

# Set to "true" to stop exporting cursor.preToolUse spans (cuts tool noise in
# traces; postToolUse / postToolUseFailure still exported with duration_ms)
CURSOR_OMIT_PRE_TOOL_USE_SPANS=false

# Set to "true" to print export debug info (trace/span IDs and errors) to stderr
CX_OTLP_DEBUG=false
