# OpenAI Codex CLI → Coralogix OTel configuration
#
# Codex supports two OTel export pipelines via config.toml:
#  - exporter       → log events (conversation, API requests, tool calls, prompts)
#  - trace_exporter → traces
#
# Note: metrics_exporter defaults to Codex's internal Statsig pipeline and does
# not support otlp-http. Metric-like counters (api_request, tool.call, etc.) are
# available as structured fields on log events via the exporter pipeline above.
#
# Setup:
#  1. Copy .env.example → .env and fill in your credentials
#  2. Source in ~/.zshrc for persistence (replace the path with the absolute path
#     to the .env file — run `pwd` inside the codex/ directory to get it):
#       if [ -f "/absolute/path/to/codex/.env" ]; then
#         set -a; source "/absolute/path/to/codex/.env"; set +a
#       fi
#  3. Merge the [otel] block below into ~/.codex/config.toml:
#       set -a; source .env; set +a
#       envsubst < config.toml.example >> ~/.codex/config.toml

[otel]
environment = "production"
log_user_prompt = false

[otel.exporter.otlp-http]
endpoint = "${CX_OTLP_ENDPOINT}/v1/logs"
protocol = "binary"

[otel.exporter.otlp-http.headers]
"Authorization" = "Bearer ${CX_API_KEY}"
"CX-Application-Name" = "${CX_APPLICATION_NAME}"
"CX-Subsystem-Name" = "${CX_SUBSYSTEM_NAME}"

[otel.trace_exporter.otlp-http]
endpoint = "${CX_OTLP_ENDPOINT}/v1/traces"
protocol = "binary"

[otel.trace_exporter.otlp-http.headers]
"Authorization" = "Bearer ${CX_API_KEY}"
"CX-Application-Name" = "${CX_APPLICATION_NAME}"
"CX-Subsystem-Name" = "${CX_SUBSYSTEM_NAME}"

# Optional: disable Codex's separate anonymous analytics to OpenAI
[analytics]
enabled = false

# ---------------------------------------------------------------------------
# Repo-tracker hook (optional)
#
# Fires after every tool call, resolves the git repo from the session cwd (and
# any file path in the tool input), and emits the OTLP gauge metric
# codex_cli_session_repo_info{session_id, repository_name, user_email}.
# session_id matches the conversation.id on Codex's native telemetry, so the
# two join downstream on that key.
#
# Reuses the CX_* credentials sourced from .env. Replace the path below with the
# absolute path to hooks/codex.py (run `pwd` inside the codex/ directory).
# ---------------------------------------------------------------------------

[[hooks.PostToolUse]]
matcher = ".*"

[[hooks.PostToolUse.hooks]]
type = "command"
command = "python3 /absolute/path/to/codex/hooks/codex.py"
timeout = 10
