                },
                "title": "Sessions by User",
                "definition": {
                  "dataTable": {
                    "query": {
                      "dataprime": {
                        "dataprimeQuery": {
                          "text": "source logs\n| filter $d.logRecord.attributes.originator == 'codex_cli_rs'\n| distinct $d.logRecord.attributes['conversation.id'], $d.logRecord.attributes['user.email']\n| countby $d.logRecord.attributes['user.email'] as user into session_count desc"
                        },
                        "filters": []
                      }
                    },
                    "resultsPerPage": 100,
                    "rowStyle": "ROW_STYLE_ONE_LINE",
                    "columns": [
                      {
                        "field": "$d.user"
                      },
                      {
                        "field": "$d.session_count"
                      }
                    ],
                    "dataModeType": "DATA_MODE_TYPE_HIGH_UNSPECIFIED"
                  }
                }
              },
              {
