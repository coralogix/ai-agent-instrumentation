{
  "//": "Coralogix hooks for GitHub Copilot CLI. Copy to ~/.copilot/hooks/coralogix.json, replace the path with the absolute path to hooks/copilot.py, and fill in the env block. Copilot injects `env` into the hook process, so credentials live here in Copilot's own settings — no shell exports or separate files. Drop the userPromptSubmitted/agentStop/sessionEnd entries if you only want repo tracking (no prompt/response capture). `install.sh` generates this for you.",
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "python3 /absolute/path/to/github-copilot-cli/hooks/copilot.py",
        "env": {
          "CX_API_KEY": "<your-send-your-data-api-key>",
          "CX_OTLP_ENDPOINT": "https://ingress.<region>.coralogix.com",
          "CX_APPLICATION_NAME": "copilot",
          "CX_SUBSYSTEM_NAME": "copilot-sessions",
          "CX_HOOK_LOG_PROMPTS": "true"
        },
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "python3 /absolute/path/to/github-copilot-cli/hooks/copilot.py",
        "env": {
          "CX_API_KEY": "<your-send-your-data-api-key>",
          "CX_OTLP_ENDPOINT": "https://ingress.<region>.coralogix.com",
          "CX_APPLICATION_NAME": "copilot",
          "CX_SUBSYSTEM_NAME": "copilot-sessions",
          "CX_HOOK_LOG_PROMPTS": "true"
        },
        "timeoutSec": 10
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "python3 /absolute/path/to/github-copilot-cli/hooks/copilot.py",
        "env": {
          "CX_API_KEY": "<your-send-your-data-api-key>",
          "CX_OTLP_ENDPOINT": "https://ingress.<region>.coralogix.com",
          "CX_APPLICATION_NAME": "copilot",
          "CX_SUBSYSTEM_NAME": "copilot-sessions",
          "CX_HOOK_LOG_PROMPTS": "true"
        },
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python3 /absolute/path/to/github-copilot-cli/hooks/copilot.py",
        "env": {
          "CX_API_KEY": "<your-send-your-data-api-key>",
          "CX_OTLP_ENDPOINT": "https://ingress.<region>.coralogix.com",
          "CX_APPLICATION_NAME": "copilot",
          "CX_SUBSYSTEM_NAME": "copilot-sessions",
          "CX_HOOK_LOG_PROMPTS": "true"
        },
        "timeoutSec": 15
      }
    ]
  }
}
